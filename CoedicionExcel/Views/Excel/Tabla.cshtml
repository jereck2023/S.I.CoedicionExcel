@using CoedicionExcel.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Tabla";
    var columnas = ViewBag.Columnas as List<ColumnaExcel>;
    var filas = ViewBag.Filas as List<Dictionary<string, object>>;
    var nombreArchivo = ViewBag.NombreArchivo as string;

    var documentoId = (int)ViewBag.DocumentoId;
    var documentoIdJson = JsonSerializer.Serialize(documentoId);

    var columnasTabulator = (columnas ?? new List<ColumnaExcel>())
        .Select(c => new
        {
            title = c.NombreVisible,
            field = c.ClaveColumna
        })
        .ToList();

    var columnasJson = JsonSerializer.Serialize(columnasTabulator);
    var filasJson = JsonSerializer.Serialize(filas ?? new List<Dictionary<string, object>>());
}

<link href="~/lib/tabulator/css/tabulator.css" rel="stylesheet" />
<script src="~/lib/tabulator/js/tabulator.js"></script>

<h2>Tabla importada</h2>
<p><strong>Archivo:</strong> @nombreArchivo</p>

<button type="button" id="btnAgregarFila" class="btn btn-success mb-3">Agregar fila</button>
<button type="button" id="btnAgregarColumna" class="btn btn-primary mb-3">Agregar columna</button>

<a href="/Excel/DescargarExcel?documentoId=@documentoId"
   class="btn btn-success mb-3">
    Descargar Excel
</a>

<div id="tabla-excel" style="margin-top:20px;"></div>

<script>
    //VARIABLES GLOBALES
    let documentoId = @ViewBag.DocumentoId;
    let versionActual = 0;
    let tabla = null;

    //OBTENER VERSIÓN INICIAL
    async function obtenerVersionInicial() {
        const response = await fetch(`/Excel/ObtenerVersionDocumento?documentoId=${documentoId}`);
        const data = await response.json();

        versionActual = data.version;
        console.log("Versión inicial:", versionActual);
    }

    //POLLING 🔁
    async function verificarCambios() {
        try {
            const response = await fetch(`/Excel/ObtenerVersionDocumento?documentoId=${documentoId}`);
            const data = await response.json();

            if (data.version !== versionActual) {
                console.log("Cambio detectado 🚨");
                //console.log("Versión nueva:", data.version);
                 await cargarSnapshot();
                //OPCIÓN SIMPLE (puedes cambiar luego)
                // location.reload();

                versionActual = data.version;
            }

        } catch (error) {
            console.error("Error en polling:", error);
        }
    }

    //CARGAR SNAPSHOT
    async function cargarSnapshot() {
        try {
            const response = await fetch(`/Excel/ObtenerSnapshotDocumento?documentoId=${documentoId}`);
            const data = await response.json();

            console.log("Recargando tabla con snapshot...");

            const columnasConEditor = data.columnas.map(c => ({
                title: c.nombreVisible,
                field: c.claveColumna,
                editor: "input",
                headerSort: false,

                titleFormatter: function (cell) {
                    const tituloActual = cell.getColumn().getDefinition().title;

                    return `
                        <div style="display:flex; justify-content:space-between; align-items:center; gap:6px;">
                            <span>${tituloActual}</span>
                            <button type="button"
                                class="btn btn-sm btn-outline-danger btn-eliminar-columna"
                                data-columna="${cell.getColumn().getField()}"
                                style="padding:2px 6px; font-size:12px;">X</button>
                        </div>
                    `;
                },

                headerDblClick: function (e, column) {
                    if (e.target.classList.contains("btn-eliminar-columna")) return;

                    const nombreActual = column.getDefinition().title;
                    const nuevoNombre = prompt("Nuevo nombre de columna:", nombreActual);

                    if (!nuevoNombre || nuevoNombre.trim() === "") return;

                    column.updateDefinition({ title: nuevoNombre });

                    fetch('/Excel/ActualizarEncabezado', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            documentoId: documentoId,
                            columna: column.getField(),
                            nombreVisible: nuevoNombre
                        })
                    });
                },

                headerClick: function (e, column) {
                    if (!e.target.classList.contains("btn-eliminar-columna")) return;

                    const campo = column.getField();

                    if (!confirm(`¿Eliminar columna "${column.getDefinition().title}"?`)) return;

                    fetch('/Excel/EliminarColumna', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            documentoId: documentoId,
                            columna: campo
                        })
                    })
                    .then(async response => {
                        if (!response.ok) throw new Error();
                        column.delete();
                    })
                    .catch(() => alert("No se pudo eliminar la columna"));
                },

                cellEdited: function (cell) {
                    const fila = cell.getRow().getData();

                    fetch('/Excel/ActualizarCelda', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            filaId: fila.filaId,
                            columna: cell.getField(),
                            valor: cell.getValue() ?? ""
                        })
                    });
                }
            }));

            columnasConEditor.push({
                title: "Acciones",
                field: "acciones",
                headerSort: false,
                formatter: () => "<button class='btn btn-danger btn-sm'>Eliminar</button>",
                width: 120,
                hozAlign: "center",

                cellClick: function (e, cell) {
                    const fila = cell.getRow().getData();

                    if (!confirm("¿Eliminar fila?")) return;

                    fetch('/Excel/EliminarFila', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ filaId: fila.filaId })
                    })
                    .then(r => {
                        if (!r.ok) throw new Error();
                        cell.getRow().delete();
                    })
                    .catch(() => alert("No se pudo eliminar"));
                }
            });

            if (tabla) {
                tabla.destroy();
            }

            tabla = new Tabulator("#tabla-excel", {
                data: data.filas,
                columns: columnasConEditor,
                layout: "fitColumns",
                minHeight: "300px",
                placeholder: "No hay datos",
                headerSort: false
            });

            versionActual = data.version;

        } catch (error) {
            console.error("Error al cargar snapshot:", error);
        }
    }

    //INICIO
    document.addEventListener("DOMContentLoaded", async function () {

        await obtenerVersionInicial();

        const documentoIdLocal = @Html.Raw(documentoIdJson);
        const columnasBase = @Html.Raw(columnasJson);
        const filas = @Html.Raw(filasJson);

        const columnasConEditor = columnasBase.map(c => ({
            ...c,
            editor: "input",
            headerSort: false,

            titleFormatter: function (cell) {
                const tituloActual = cell.getColumn().getDefinition().title;

                return `
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:6px;">
                        <span>${tituloActual}</span>
                        <button type="button"
                            class="btn btn-sm btn-outline-danger btn-eliminar-columna"
                            data-columna="${cell.getColumn().getField()}"
                            style="padding:2px 6px; font-size:12px;">X</button>
                    </div>
                `;
            },

            headerDblClick: function (e, column) {
                if (e.target.classList.contains("btn-eliminar-columna")) return;

                const nombreActual = column.getDefinition().title;
                const nuevoNombre = prompt("Nuevo nombre de columna:", nombreActual);

                if (!nuevoNombre || nuevoNombre.trim() === "") return;

                column.updateDefinition({ title: nuevoNombre });

                fetch('/Excel/ActualizarEncabezado', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        documentoId: documentoIdLocal,
                        columna: column.getField(),
                        nombreVisible: nuevoNombre
                    })
                });
            },

            headerClick: function (e, column) {
                if (!e.target.classList.contains("btn-eliminar-columna")) return;

                const campo = column.getField();

                if (!confirm(`¿Eliminar columna "${column.getDefinition().title}"?`)) return;

                fetch('/Excel/EliminarColumna', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        documentoId: documentoIdLocal,
                        columna: campo
                    })
                })
                .then(async response => {
                    if (!response.ok) throw new Error();
                    column.delete();
                })
                .catch(() => alert("No se pudo eliminar la columna"));
            },

            cellEdited: function (cell) {
                const fila = cell.getRow().getData();

                fetch('/Excel/ActualizarCelda', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        filaId: fila.filaId,
                        columna: cell.getField(),
                        valor: cell.getValue() ?? ""
                    })
                });
            }
        }));

        // ACCIONES
        columnasConEditor.push({
            title: "Acciones",
            field: "acciones",
            headerSort: false,
            formatter: () => "<button class='btn btn-danger btn-sm'>Eliminar</button>",
            width: 120,
            hozAlign: "center",

            cellClick: function (e, cell) {
                const fila = cell.getRow().getData();

                if (!confirm("¿Eliminar fila?")) return;

                fetch('/Excel/EliminarFila', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filaId: fila.filaId })
                })
                .then(r => {
                    if (!r.ok) throw new Error();
                    cell.getRow().delete();
                })
                .catch(() => alert("No se pudo eliminar"));
            }
        });

        // TABLA
        tabla = new Tabulator("#tabla-excel", {
            data: filas,
            columns: columnasConEditor,
            layout: "fitColumns",
            minHeight: "300px",
            placeholder: "No hay datos",
            headerSort: false
        });

        // AGREGAR FILA
        document.getElementById("btnAgregarFila").addEventListener("click", function () {
            fetch('/Excel/AgregarFila', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    documentoId: documentoIdLocal
                })
            })
            .then(r => r.json())
            .then(f => tabla.addRow(f))
            .catch(() => alert("Error fila"));
        });

        // AGREGAR COLUMNA
        document.getElementById("btnAgregarColumna").addEventListener("click", function () {
            const nombre = prompt("Nombre columna:");
            if (!nombre) return;

            fetch('/Excel/AgregarColumna', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    documentoId: documentoIdLocal,
                    nombre: nombre
                })
            })
            .then(r => r.json())
            .then(col => {
                tabla.addColumn({
                    title: col.nombre,
                    field: col.clave,
                    editor: "input"
                }, true);
            })
            .catch(() => alert("Error columna"));
        });

        // INICIAR POLLING
        setInterval(verificarCambios, 3000);

        window.tablaDebug = tabla;
    });
</script>